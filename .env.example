# ===== Telegram Bot =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=https://your-domain.com/webhook/telegram

# ===== Google Drive =====
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# ===== Google Sheets (for reports) =====
GOOGLE_SHEETS_ID=your_google_sheets_id

# ===== Ollama AI (Cloud) =====
OLLAMA_BASE_URL=https://api.ollama.com
OLLAMA_API_KEY=your_ollama_api_key_here
OLLAMA_MODEL=gemma3
OLLAMA_VISION_MODEL=gemma3

# ===== Email (SMTP) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
REPORT_EMAIL_RECIPIENTS=recipient1@email.com,recipient2@email.com

# ===== App Settings =====
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./documents.db
DAILY_REPORT_HOUR=8
WEEKLY_REPORT_DAY=monday
WEEKLY_REPORT_HOUR=9
